# Facebook Pixel & CAPI Configuration

# Client-side (Vite)
VITE_FACEBOOK_PIXEL_ID=YOUR_PIXEL_ID_HERE

# Server-side (Vercel/Node)
FACEBOOK_PIXEL_ID=YOUR_PIXEL_ID_HERE
FACEBOOK_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE
FACEBOOK_TEST_EVENT_CODE=TEST12345 # Optional: For testing in Events Manager

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=https://your-domain.com

# Shopify Integration (Optional - for Order Management)
# Leave empty if you don't want to sync orders to Shopify
SHOPIFY_STORE_NAME=your-store-name # e.g. "my-shop" from my-shop.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_... # Admin API Access Token
SHOPIFY_PRODUCT_ID_1=123456789 # Product ID for 1-Pack
SHOPIFY_PRODUCT_ID_2=123456789 # Product ID for 3-Pack
SHOPIFY_PRODUCT_ID_3=123456789 # Product ID for 6-Pack
